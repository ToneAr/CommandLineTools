Cell[BoxData[
 RowBox[{"code", " ", "=", " ", 
  RowBox[{"HoldComplete", "[", "\n", "\t", 
   RowBox[{"Enclose", "[", "\[IndentingNewLine]", "\t\t", 
    RowBox[{
     RowBox[{
      RowBox[{"CommandLineTools", " ", "=", " ", 
       RowBox[{"ResourceFunction", "[", "\"\<CommandLineTools\>\"", "]"}]}], ";",
       " ", "\[IndentingNewLine]", "\t\t", 
      RowBox[{
      "helpMessage", " ", "=", " ", "\"\<Usage: script [options]\>\""}], ";", 
      " ", "\n", "\t\t", 
      RowBox[{"(*", " ", 
       RowBox[{"Set", " ", "session", " ", "options"}], " ", "*)"}], 
      "\[IndentingNewLine]", "\t\t", 
      RowBox[{"SetOptions", "[", 
       RowBox[{
       "CommandLineTools", ",", " ", "\[IndentingNewLine]", "\t\t\t", 
        RowBox[{"\"\<ArgumentSpecification\>\"", " ", "->", " ", 
         RowBox[{"{", "\n", "\t\t\t\t", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"\"\<initialize\>\"", ",", "  ", "\"\<i\>\""}], "}"}], ",",
            "\n", "\t\t\t\t", 
           RowBox[{"{", 
            RowBox[{"\"\<help\>\"", ",", "        ", "\"\<h\>\""}], "}"}], ",",
            "\n", "\t\t\t\t", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"\"\<port\>\"", ",", "        ", "\"\<p\>\""}], "}"}], 
            " ", "->", " ", 
            RowBox[{"_Integer", " ", "->", " ", "30400"}]}], ",", "\n", 
           "\t\t\t\t", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"\"\<hostname\>\"", ",", "    ", "\"\<n\>\""}], "}"}], 
            " ", "->", " ", 
            RowBox[{"_String", " ", "->", " ", "\"\<localhost\>\""}]}]}], 
          "\n", "\t\t\t", "}"}]}], ",", "\n", "\t\t\t", 
        RowBox[{"\"\<HelpMessage\>\"", " ", "->", " ", "helpMessage"}], ",", 
        "\n", "\t\t\t", 
        RowBox[{"\"\<StrictParse\>\"", " ", "->", " ", "True"}], ",", "\n", 
        "\t\t\t", 
        RowBox[{"\"\<InterfacePrompt\>\"", " ", "->", 
         " ", "\"\<wl-http-server>\>\""}], ",", "\n", "\t\t\t", 
        RowBox[{"\"\<LogDirectory\>\"", " ", "->", 
         " ", "\"\<./logs/http-server\>\""}]}], "\n", "\t\t", "]"}], ";", " ",
       "\n", "\t\t", 
      RowBox[{"(*", " ", 
       RowBox[{"Print", " ", "help", " ", "if", " ", "nessesary"}], " ", 
       "*)"}], "\n", "\t\t", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"CommandLineTools", "[", 
         RowBox[{"\"\<Parse\>\"", ",", " ", 
          RowBox[{"\"\<h\>\"", " ", "|", " ", "\"\<help\>\""}]}], "]"}], ",", 
        "\n", "\t\t\t", 
        RowBox[{
         RowBox[{"CommandLineTools", "[", "\"\<Help\>\"", "]"}], ";", "\n", 
         "\t\t\t", 
         RowBox[{"Exit", "[", "]"}]}]}], "\n", "\t\t", "]"}], ";", "\n", 
      "\t\t", 
      RowBox[{"(*", " ", 
       RowBox[{"Check", " ", "for", " ", "a", " ", "flag"}], " ", "*)"}], 
      "\n", "\t\t", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"CommandLineTools", "[", 
         RowBox[{"\"\<Parse\>\"", ",", " ", 
          RowBox[{"\"\<i\>\"", "|", "\"\<initialize\>\""}]}], "]"}], ",", 
        "\n", "\t\t\t", 
        RowBox[{
         RowBox[{"CommandLineTools", "[", 
          
          RowBox[{"\"\<Log\>\"", ",", " ", "\"\<INFO\>\"", ",", 
           " ", "\"\<Installing LocalDeploy\>\""}], "]"}], ";", "\n", 
         "\t\t\t", 
         RowBox[{
         "PacletInstall", "[", "\"\<ToneAr/LocalDeploy\>\"", "]"}]}]}], "\n", 
       "\t\t", "]"}], ";", "\n", "\t\t", 
      RowBox[{"(*", " ", 
       RowBox[{"Parse", " ", "arguments"}], " ", "*)"}], "\n", "\t\t", 
      RowBox[{"port", " ", "=", " ", 
       RowBox[{"Confirm", " ", "@", " ", 
        RowBox[{"CommandLineTools", "[", 
         RowBox[{"\"\<Parse\>\"", ",", " ", 
          RowBox[{"\"\<p\>\"", " ", "|", " ", "\"\<port\>\""}]}], "]"}]}]}], ";",
       "\n", "\t\t", 
      RowBox[{"host", " ", "=", " ", 
       RowBox[{"Confirm", " ", "@", " ", 
        RowBox[{"CommandLineTools", "[", 
         RowBox[{"\"\<Parse\>\"", ",", " ", 
          RowBox[{"\"\<h\>\"", " ", "|", " ", "\"\<hostname\>\""}]}], 
         "]"}]}]}], ";", "\[IndentingNewLine]", "\t\t", 
      RowBox[{"(*", " ", 
       RowBox[{
       "Deploy", " ", "an", " ", "example", " ", "HTTP", " ", "server", " ", 
        "using", " ", "the", " ", "parse", " ", "input"}], " ", "*)"}], "\n", 
      "\t\t", 
      RowBox[{"deployment", " ", "=", "\n", "\t\t\t", 
       RowBox[{"Confirm", " ", "@", "\n", "\t\t\t", 
        RowBox[{
         RowBox[{"PacletSymbol", "[", 
          
          RowBox[{"\"\<ToneAr/LocalDeploy\>\"", ",", 
           " ", "\"\<LocalDeploy\>\""}], "]"}], "[", "\n", "\t\t\t\t", 
         RowBox[{
          RowBox[{"APIFunction", "[", 
           RowBox[{
            RowBox[{"{", "\n", "\t\t\t\t\t\t", 
             RowBox[{
              RowBox[{"\"\<min\>\"", " ", "->", " ", 
               RowBox[{"\"\<Number\>\"", " ", "->", " ", 
                RowBox[{"-", "10"}]}]}], ",", " ", "\n", "\t\t\t\t\t\t", 
              RowBox[{"\"\<max\>\"", " ", "->", " ", 
               RowBox[{"\"\<Number\>\"", " ", "->", " ", "10"}]}]}], "\n", 
             "\t\t\t\t\t", "}"}], ",", " ", "\n", "\t\t\t\t\t", 
            RowBox[{
             RowBox[{"Function", "[", "\n", "\t\t\t\t\t\t", 
              RowBox[{"Plot", "[", 
               RowBox[{
                RowBox[{"Fibonacci", "[", 
                 RowBox[{
                  RowBox[{"1", "/", "2"}], ",", " ", "x"}], "]"}], ",", " ", 
                RowBox[{"{", 
                 RowBox[{"x", ",", " ", "#min", ",", " ", "#max"}], "}"}]}], 
               "]"}], "\n", "\t\t\t\t\t", "]"}], "&"}], ",", "\n", 
            "\t\t\t\t\t", "\"\<SVG\>\""}], "\n", "\t\t\t\t", "]"}], ",", "\n",
           "\t\t\t\t", "port", ",", "\n", "\t\t\t\t", 
          RowBox[{"\"\<HostAddress\>\"", " ", "->", " ", "host"}]}], "\n", 
         "\t\t\t", "]"}]}]}], ";", " ", "\[IndentingNewLine]", "\t\t", 
      RowBox[{"(*", " ", 
       RowBox[{"Log", " ", "message"}], " ", "*)"}], "\n", "\t\t", 
      RowBox[{"CommandLineTools", "[", 
       RowBox[{"\"\<Log\>\"", ",", " ", "\"\<INFO\>\"", ",", "\n", "\t\t\t", 
        RowBox[{"StringJoin", "[", "\n", "\t\t\t\t", 
         RowBox[{"\"\<Running HTTP server on: \>\"", ",", "\n", "\t\t\t\t", 
          RowBox[{
           RowBox[{"ResourceFunction", "[", "\"\<ANSITools\>\"", "]"}], "[", 
           RowBox[{"\"\<Style\>\"", ",", "\n", "\t\t\t\t\t", 
            
            RowBox[{"\"\<http://\>\"", "<>", "host", "<>", "\"\<:\>\"", "<>", 
             
             RowBox[{"ToString", "[", "port", "]"}]}], ",", "\n", 
            "\t\t\t\t\t", "Blue"}], "\n", "\t\t\t\t", "]"}]}], "\n", "\t\t\t",
          "]"}]}], "\n", "\t\t", "]"}], ";", "\n", "\t\t", 
      RowBox[{"(*", " ", 
       RowBox[{"Create", " ", "interactive", " ", "interface"}], " ", "*)"}], 
      "\n", "\t\t", 
      RowBox[{"CommandLineTools", "[", "\"\<Interface\>\"", "]"}]}], "\n", 
     "\t\t", ",", 
     RowBox[{"(*", " ", "OnError", " ", "*)"}], "\n", "\t\t", 
     RowBox[{"Function", "[", 
      RowBox[{"e", ",", "\n", "\t\t\t", 
       RowBox[{"CommandLineTools", "[", 
        RowBox[{"\"\<Log\>\"", ",", " ", "\"\<ERROR\>\"", ",", " ", 
         RowBox[{"Replace", "[", 
          RowBox[{
           RowBox[{"e", "[", "\"\<Information\>\"", "]"}], ",", " ", 
           RowBox[{
            RowBox[{"Except", "[", "_String", "]"}], " ", "->", " ", 
            RowBox[{"ToString", "[", "e", "]"}]}]}], "]"}]}], "]"}]}], "\n", 
      "\t\t", "]"}]}], "\n", "\t", "]"}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 TaggingRules->{},
 CellChangeTimes->{{3.970153770832568*^9, 3.970153772387226*^9}},
 CellID->1818309764,ExpressionUUID->"52dd3460-cc8d-4b66-b498-cc010936ca3b"],

