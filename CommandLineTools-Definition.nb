Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SetOptions", "[", 
   RowBox[{"CommandLineTools", ",", "\[IndentingNewLine]", 
    RowBox[{"\"\<CommandLine\>\"", " ", "->", 
     " ", "\"\<command -ab 10 --flag -c abc 12345\>\""}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"\"\<POSIX\>\"", "->", "True"}], ",", "\[IndentingNewLine]", 
    RowBox[{"\"\<ArgumentSpecification\>\"", " ", "->", " ", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"\"\<$1\>\"", " ", "->", " ", "_Integer"}], ",", 
       "\[IndentingNewLine]", "\"\<flag\>\"", ",", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"\"\<flag2\>\"", ",", " ", "\"\<a\>\""}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"\"\<flag3\>\"", ",", " ", "\"\<b\>\""}], "}"}], " ", "->", 
        " ", "_Integer"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"\"\<flag4\>\"", ",", " ", "\"\<c\>\""}], "}"}], " ", "->", 
        " ", 
        RowBox[{"_String", " ", "->", " ", "\"\<default\>\""}]}]}], 
      "\[IndentingNewLine]", "}"}]}]}], "\[IndentingNewLine]", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"parsed", " ", "=", 
   RowBox[{"CommandLineTools", "[", "\"\<Parse\>\"", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Dataset", "[", 
   RowBox[{
    RowBox[{"TabularSchema", "[", 
     RowBox[{
      RowBox[{"Tabular", " ", "@*", " ", "List"}], " ", "@", " ", "parsed"}], 
     "]"}], "[", "\"\<RawSchema\>\"", "]"}], "]"}], 
  "[", "\"\<ColumnProperties\>\"", "]"}]}], "Input",
 TaggingRules-><|
