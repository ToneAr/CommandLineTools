Cell[BoxData[{
 RowBox[{
  RowBox[{"SetOptions", "[", 
   RowBox[{"CommandLineTools", ",", "\[IndentingNewLine]", 
    RowBox[{"\"\<HelpMessage\>\"", " ", "->", 
     " ", "\"\<CommandLineTools documentation example message\>\""}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"\"\<InterfaceCommands\>\"", " ", "->", " ", 
     RowBox[{"<|", "\[IndentingNewLine]", "\t", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"\"\<c\>\"", " ", "|", " ", "\"\<custom\>\""}], ",", 
          " ", "\"\<Print x to the console\>\""}], "}"}], ":>", " ", 
        RowBox[{"Print", "[", "x", "]"}]}], ",", "\[IndentingNewLine]", "\t", 
       
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"\"\<q\>\"", " ", "|", " ", "\"\<quit\>\""}], ",", 
          " ", "\"\<Quit the program\>\""}], "}"}], " ", ":>", " ", 
        RowBox[{"Exit", "[", "0", "]"}]}], ",", "\[IndentingNewLine]", "\t", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
