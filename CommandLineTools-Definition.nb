Cell[TextData[{
 "With \"POSIX\" set to ",
 Cell[BoxData[
  TagBox[
   ButtonBox[
    StyleBox["True", "SymbolsRefLink",
     ShowStringCharacters->True,
     FontFamily->"Source Sans Pro"],
    BaseStyle->Dynamic[
      FEPrivate`If[
       CurrentValue["MouseOver"], {
       "Link", FontColor -> RGBColor[0.8549, 0.39608, 0.1451]}, {"Link"}]],
    ButtonData->"paclet:ref/True",
    ContentPadding->False],
   MouseAppearanceTag["LinkHand"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e367ba04-dd45-4cfc-8f29-380cc829fd41"],
 ", short options are split into single letter shorthands. For example, \
\"-abc 10\" will be parsed as ",
 Cell[BoxData[
  RowBox[{
   StyleBox["<|", "Input"], 
   RowBox[{
    RowBox[{
     RowBox[{
      StyleBox["\"\<\>", "Code"], 
      StyleBox["a", "TI"], 
      StyleBox["\"\<\>", "Code"]}], 
     StyleBox["->", "Code"], 
     StyleBox[" ", "Code"], 
     StyleBox["True", "Code"]}], 
    StyleBox[",", "Code"], 
    RowBox[{
     RowBox[{
      StyleBox["\"\<\>", "Code"], 
      StyleBox["b", "TI"], 
      StyleBox["\"\<\>", "Code"]}], 
     StyleBox["->", "Code"], 
     StyleBox[" ", "Code"], 
     StyleBox["True", "Code"]}], 
    StyleBox[",", "Code"], 
    RowBox[{
     RowBox[{
      StyleBox["\"\<\>", "Code"], 
      StyleBox["c", "TI"], 
      StyleBox["\"\<\>", "Code"]}], 
     StyleBox["->", "Code"], 
     StyleBox["\"\<10\>\"", "Code"]}]}], 
   StyleBox["|>", "Input"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f7943aeb-c543-41af-bb37-45d501971824"],
 "."
}], "Notes",
 TaggingRules-><|
  "ChatNotebookSettings" -> <|
    "PersonaFavorites" -> {"CodeAssistant", "CodeWriter", "PlainChat"}, 
     "CurrentPreferencesTab" -> "Services", "InheritanceTest" -> True, 
